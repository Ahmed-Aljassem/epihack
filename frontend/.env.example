# Local development environment variables.
# Copy to `.env` and fill in values; `.env` is gitignored.

# Backend API base. Leave blank to use the local Vite proxy or Docker Nginx proxy.
VITE_API_BASE_URL=

# Mapbox public access token (https://account.mapbox.com/access-tokens).
# Required for the Reports map. Without it, the map renders a static placeholder.
VITE_MAPBOX_TOKEN=
